    IDX -->|"tasks + agent"| ER
    ER -->|"act(state)"| CALLER
    ER -->|"reset / step(CallerAction)"| ENV
    ER -->|"log turns + summaries"| LOG

    CALLER -->|"messages.create"| ANTHROPIC_C
    ANTHROPIC_C -->|"tool_use block"| CALLER
    CALLER -->|"AgentAction"| ER

    ENV -->|"handleUtterance(text)"| VA
    TASKS -->|"Task"| ENV
    REWARD -->|"reward delta"| ENV

    VA -->|"messages.create"| ANTHROPIC_V
    ANTHROPIC_V -->|"tool_use block"| VA
    VA -->|"callTool(name, args)"| CLIENT

    CLIENT <-->|"JSON-RPC"| TRANSPORT
    TRANSPORT <-->|"JSON-RPC"| SERVER

    SERVER -->|"lookup / getField"| STORE
    STORE -->|"Zod.parse"| JSON

    STORE -.->|"ground truth for reward eval"| ENV
