{
  "name": "voice-agent-env",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "start": "tsx src/index.ts",
    "golden": "tsx src/golden-run.ts",
    "stress": "tsx src/stress-run.ts",
    "experiment:init": "node --import tsx src/cli/experiment-init.ts",
    "experiment:step": "node --import tsx src/cli/experiment-step.ts",
    "experiment:loop": "node --import tsx src/cli/experiment-loop.ts",
    "experiment:show": "node --import tsx src/cli/experiment-show.ts",
    "experiment:reset": "node --import tsx src/cli/experiment-reset.ts",
    "policy:show": "node --import tsx src/cli/policy-show.ts",
    "test": "node --import tsx --test test/**/*.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.40.0",
    "@modelcontextprotocol/sdk": "^1.10.0",
    "chalk": "^5.4.1",
    "dotenv": "^16.0.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  }
}
